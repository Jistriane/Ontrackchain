COMPOSE_PROJECT_NAME=ontrackchain-staging

POSTGRES_USER=ontrackchain
POSTGRES_PASSWORD=__FILL_STAGING_POSTGRES_PASSWORD__
POSTGRES_DB=ontrackchain
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

COMPOSE_NETWORK_NAME=ontrackchain

PUBLIC_API_PORT=8000
INVESTIGATION_API_PORT=8001
COMPLIANCE_API_PORT=8002
MONITORING_API_PORT=8003
REPORT_API_PORT=8004
AUTH_SERVICE_PORT=9000

TRAEFIK_HTTP_PORT=8080
TRAEFIK_DASHBOARD_PORT=8081
KEYCLOAK_HTTP_PORT=8088
PROMETHEUS_PORT=9091
GRAFANA_PORT=3002
ALERTMANAGER_PORT=9093

APP_ENV=staging
AUTH_MODE=oidc
DEV_AUTH_ENABLED=false
NEXT_PUBLIC_AUTH_MODE=oidc
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_DEV_AUTH_ENABLED=false
OIDC_PROVIDER=keycloak
INTERNAL_API_BASE_URL=http://traefik
INTERNAL_AUTH_BASE_URL=http://auth-service:9000
INTERNAL_KEYCLOAK_BASE_URL=http://keycloak:8080
NEXT_PUBLIC_API_BASE_URL=https://app.staging.ontrackchain.com
ONTRACKCHAIN_FRONTEND_HEALTHCHECK_BASE_URL=https://app.staging.ontrackchain.com
ONTRACKCHAIN_EXPECT_FRONTEND_DEPLOYMENT_MODEL=render-full-stack-staging
ONTRACKCHAIN_ALLOW_FRONTEND_SHOWCASE_FALLBACK=false
KEYCLOAK_PUBLIC_URL=https://auth.staging.ontrackchain.com
KEYCLOAK_HOSTNAME=auth.staging.ontrackchain.com
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=__FILL_STAGING_KEYCLOAK_ADMIN_PASSWORD__
KEYCLOAK_REALM=ontrackchain
KEYCLOAK_B2B_CLIENT_SECRET=__FILL_STAGING_KEYCLOAK_B2B_CLIENT_SECRET__

JWT_ISSUER=ontrackchain
JWT_AUDIENCE=ontrackchain-api
JWT_HS256_SECRET=__FILL_STAGING_JWT_HS256_SECRET__
MFA_TOTP_SECRET=__FILL_STAGING_MFA_TOTP_SECRET__
MFA_TOTP_ISSUER=OnTrackChain
MFA_TOTP_ACCOUNT_NAME=staging-admin@ontrackchain
MFA_TOTP_PERIOD_SECONDS=30
MFA_TOTP_DIGITS=6
MFA_TOTP_WINDOW=1
MFA_EXTERNAL_PROVIDER_HOMOLOGATED=false
ONTRACKCHAIN_HOMOLOGATION_OIDC_TOKEN=__FILL_STAGING_HOMOLOGATION_OIDC_TOKEN__
OIDC_ISSUER_URL=https://auth.staging.ontrackchain.com/realms/ontrackchain
OIDC_AUDIENCE=ontrackchain-api
OIDC_CLIENT_ID=ontrackchain-web
OIDC_JWKS_URL=https://auth.staging.ontrackchain.com/realms/ontrackchain/protocol/openid-connect/certs
OIDC_AUTHORIZATION_URL=https://auth.staging.ontrackchain.com/realms/ontrackchain/protocol/openid-connect/auth
OIDC_ORG_CLAIM=org
OIDC_PLAN_CLAIM=plan
OIDC_ROLE_CLAIM=otk_role
ONTRACKCHAIN_ALLOW_INSECURE_OIDC_URLS=false
ONTRACKCHAIN_ALLOW_LOCALHOST_OIDC_URLS=false

CREDIT_VALUE_BRL=1.0
INVESTIGATION_INTERNAL_METRICS_ENABLED=true
INVESTIGATION_WORKER_PROCESSING_SECONDS=2
INVESTIGATION_WORKER_LOCAL_CONCURRENCY=8
INVESTIGATION_WORKER_BASE_BACKOFF_SECONDS=5
INVESTIGATION_RPC_PROVIDER=evm_rpc
INVESTIGATION_RPC_ENABLED=true
# manter vazio quando ONTRACKCHAIN_EXPECT_RPC_MODE=fallback_only
INVESTIGATION_RPC_PRIMARY_URL=
INVESTIGATION_RPC_FALLBACK_URL=__FILL_STAGING_RPC_FALLBACK_URL__
INVESTIGATION_RPC_TIMEOUT_MS=1500
INVESTIGATION_RPC_MAX_RETRIES=1

MONITORING_INTERNAL_METRICS_ENABLED=true
MONITORING_ALERTS_LAST_HOUR_WARN_THRESHOLD=5
MONITORING_CRITICAL_ALERTS_LAST_24H_CRITICAL_THRESHOLD=1
MONITORING_EXPIRED_QUOTES_WARN_THRESHOLD=10
MONITORING_OPEN_QUOTES_WARN_THRESHOLD=25
ALERTMANAGER_WEBHOOK_BEARER_TOKEN=__FILL_STAGING_ALERTMANAGER_WEBHOOK_BEARER_TOKEN__

COMPLIANCE_INTERNAL_METRICS_ENABLED=true
COMPLIANCE_QUEUED_CASES_WARN_THRESHOLD=5
COMPLIANCE_FAILED_LAST_24H_CRITICAL_THRESHOLD=1
COMPLIANCE_EXPIRED_QUOTES_WARN_THRESHOLD=10
COMPLIANCE_COMPLETED_WITHOUT_REPORT_WARN_THRESHOLD=3
COMPLIANCE_PROVIDER_DEGRADED_WARN_THRESHOLD=1
COMPLIANCE_RISK_PROVIDER=trm_labs
COMPLIANCE_TRM_ENABLED=true
COMPLIANCE_TRM_SCREENING_URL=__FILL_STAGING_TRM_SCREENING_URL__
COMPLIANCE_TRM_API_KEY=__FILL_STAGING_TRM_API_KEY__
COMPLIANCE_TRM_API_KEY_HEADER=Authorization
COMPLIANCE_TRM_API_KEY_PREFIX=Bearer 
COMPLIANCE_TRM_TIMEOUT_MS=1500
COMPLIANCE_TRM_MAX_RETRIES=1
OPENSANCTIONS_API_KEY=__FILL_STAGING_OPENSANCTIONS_API_KEY__
COMPLIANCE_OFAC_SDN_SOURCE_URL=
COMPLIANCE_EU_SANCTIONS_SOURCE_URL=__FILL_STAGING_COMPLIANCE_EU_SANCTIONS_SOURCE_URL__
ONTRACKCHAIN_ALLOW_INSECURE_PROVIDER_URLS=false
ONTRACKCHAIN_ALLOW_LOCAL_PROVIDER_URLS=false

REPORT_INTERNAL_METRICS_ENABLED=true
REPORT_DOWNLOADS_LAST_24H_WARN_THRESHOLD=10
REPORT_PENDING_ONCHAIN_WARN_THRESHOLD=3
REPORT_LEGAL_DOWNLOAD_SECURITY_VIOLATION_THRESHOLD=1
REPORT_PERSISTED_WITHOUT_DOWNLOAD_WARN_THRESHOLD=3

ONTRACKCHAIN_EXPECT_COMPLIANCE_MODE=live
ONTRACKCHAIN_EXPECT_RPC_MODE=fallback_only

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__FILL_STAGING_GRAFANA_ADMIN_PASSWORD__
GRAFANA_ANONYMOUS_ENABLED=false
GRAFANA_DISABLE_LOGIN_FORM=false
